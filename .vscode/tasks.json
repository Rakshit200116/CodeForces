{
      "version": "2.0.0",
      "tasks": [
            {
                  "type": "cppbuild",
                  "label": "Build C++",
                  "command": "/usr/bin/g++",
                  "args": [
                        "-fdiagnostics-color=always",
                        "-g",
                        "${file}",
                        "-o",
                        "/home/rakshit-jain/Documents/Executables/${fileBasenameNoExtension}"
                  ],
                  "options": {
                        "cwd": "${fileDirname}"
                  },
                  "problemMatcher": [
                        "$gcc"
                  ],
                  "group": {
                        "kind": "build",
                        "isDefault": true
                  }
            }
      ]
}